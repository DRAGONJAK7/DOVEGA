# ====================== Port Scanner ======================
def port_scan(target):
    print(Fore.GREEN + f"\n[+] Scanning ports on {target}...")
    common_ports = [21, 22, 23, 25, 80, 139, 443, 445, 3306, 8080]
    for port in common_ports:
        try:
            s = socket.socket(socket.AF_INET, socket.SOCK_STREAM)
            s.settimeout(1)
            result = s.connect_ex((target, port))
            if result == 0:
                print(Fore.CYAN + f"[+] Port {port} OPEN")
            s.close()
        except:
            pass

# ====================== Send Payload ======================
def send_payload(target, port, payload={("hello")}):
    try:
        s = socket.socket(socket.AF_INET, socket.SOCK_STREAM)
        s.connect((target, port))
        s.send(payload.encode())
        print(Fore.GREEN + f"[+] Payload sent successfully to {target}:{port}")
        try:
            response = s.recv(1024).decode(errors="ignore")
            print(Fore.CYAN + f"[+] Response: {response}")
        except:
            print(Fore.YELLOW + "[!] No response from target.")
        s.close()
    except Exception as e:
        print(Fore.RED + f"[-] Failed to send payload: {e}")

# ====================== Web Scanner ======================
def web_scan(url):
    try:
        r = requests.get(url, timeout=5)
        print("\n[+] Server Headers:")
        for k, v in r.headers.items():
            print(f"   {k}: {v}")

        if "X-Frame-Options" not in r.headers:
            print("[-] Missing X-Frame-Options (clickjacking risk)")
        if "X-XSS-Protection" not in r.headers:
            print("[-] Missing X-XSS-Protection")
        if "Server" in r.headers:
            print(f"[i] Server info: {r.headers['Server']}")
    except Exception as e:
        print(f"[!] Error in web_scan: {e}")

